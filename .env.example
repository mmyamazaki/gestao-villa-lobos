# Copie para .env e preencha. Nunca commite o arquivo .env.
# O servidor Express carrega este arquivo automaticamente (dotenv).
# `npm run dev` executa scripts/predev.mjs antes: libera API_PORT, valida variáveis e testa o Prisma.

# Supabase — conexão do Prisma (Database → connection string).
# Recomendado: host db.<ref>.supabase.co na porta 5432 (sessão direta).
# Se usar *.pooler.supabase.com:6543, o servidor acrescenta pgbouncer=true + connection_limit=1 (não troca para 5432).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Porta da API Express. Em PaaS o host injeta PORT — tem prioridade. API_PORT só para dev local (npm run dev).
API_PORT=3333
# NODE_ENV=production
# Bind HTTP: em produção sem PORT, o servidor usa 127.0.0.1 (Hostinger). BIND_ALL_INTERFACES=1 → 0.0.0.0
# LISTEN_HOST=127.0.0.1
# BIND_ALL_INTERFACES=1
# Origens permitidas no CORS (separadas por vírgula). Se vazio, qualquer origem (útil com mesmo host).
# ALLOWED_ORIGINS=https://seu-dominio.hostingersite.com

# Base da API no navegador (obrigatória se o frontend e o Node estão em domínios diferentes).
# Ex.: site em https://seudominio.com e API em https://api.seudominio.com → VITE_API_BASE_URL=https://api.seudominio.com
# Se vazio, o browser chama /api no MESMO host que serviu o JS — site só estático não tem /api (parcelas não sincronizam).
# VITE_API_BASE_URL=
# API_DEBUG=1

# Supabase — cliente no navegador (Settings → API: Project URL + anon public key).
# Com site só estático (sem Node), o app lê cursos/professores/alunos direto do Supabase se a API /api falhar.
# Se aparecer erro de permissão, execute no Supabase SQL o ficheiro prisma/sql/rls_anon_read_school_core.sql
# Se houver inconsistência (ex.: mensalidades aparecem e alunos não), rode prisma/sql/rls_repair_anon_read_core.sql
# Mensalidades (parcelas): sem API acessível, o app pode ler/gravar a tabela "Mensalidade" pela anon key SE executar
# prisma/sql/rls_anon_mensalidade.sql (só intranet/dev; produção pública deve usar API Node + rls_secure_production.sql).
VITE_SUPABASE_URL="https://SEU_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# E-mail do administrador principal (só identificação na UI; mesmo e-mail deve existir na tabela admins).
VITE_ADMIN_EMAIL="seu-email@exemplo.com"

# Segredo para assinar o cookie de sessão admin (mín. 8 caracteres). Obrigatório em produção.
# Gere algo aleatório, ex.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET="troque-por-uma-string-longa-e-aleatoria"

# EMERGÊNCIA (só no servidor Node — nunca prefixo VITE_): senha provisória com mín. 8 caracteres.
# - Se já existir utilizador em `admins`, aceita esta senha além do hash (para recuperar acesso).
# - Se não existir ninguém, o e-mail de login deve ser o de ADMIN_EMAIL ou VITE_ADMIN_EMAIL e cria o admin.
# Remova esta variável no painel (Hostinger) depois de definir a senha definitiva em Configurações.
# Exemplo de valor forte: EMVL-Resgate-2026!
# ADMIN_PROVISIONAL_PASSWORD=

# Senha em texto puro só para o seed gravar o hash em `admins` (nunca no frontend).
# npm run db:seed  — usa ADMIN_EMAIL (opcional) ou VITE_ADMIN_EMAIL + ADMIN_PASSWORD
# ADMIN_EMAIL="seu-email@exemplo.com"
# ADMIN_PASSWORD="senha_segura_do_admin"

# Sincroniza e-mail/senha na tabela admins (hash bcrypt):
#   npm run db:seed
#
# RLS: em produção execute prisma/sql/rls_secure_production.sql (bloqueia anon nas tabelas).
# O teu Mac continua a poder editar tudo com DATABASE_URL (Prisma CLI, Supabase SQL/Table Editor).
# Administradores no app: rotas /api/admins com cookie de sessão (não usar anon na tabela admins).
