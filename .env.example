# Copie para .env e preencha. Nunca commite o arquivo .env.
# O servidor Express carrega este arquivo automaticamente (dotenv).
# `npm run dev` executa scripts/predev.mjs antes: libera API_PORT, valida variáveis e testa o Prisma.

# Supabase — conexão do Prisma (Database → connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Porta da API Express (obrigatório alinhar: proxy Vite + wait-api + server usam API_PORT)
API_PORT=3333
# API_DEBUG=1

# Supabase — cliente no navegador (Settings → API: Project URL + anon public key)
VITE_SUPABASE_URL="https://SEU_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Administrador principal (sempre aceito no login; não pode ser excluído na tela de Configurações)
VITE_ADMIN_EMAIL="seu-email@exemplo.com"
VITE_ADMIN_PASSWORD="sua_senha_segura"

# Sincroniza o mesmo e-mail/senha na tabela admins (hash bcrypt):
#   npm run db:seed
#
# RLS: se insert/select falhar no app, em SQL ou Table Editor desative RLS na tabela `admins`
# ou crie policies adequadas (em produção use Edge Function ou service role só no servidor).
