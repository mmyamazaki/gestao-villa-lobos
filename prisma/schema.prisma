// Schema alinhado ao domínio do sistema (persistência futura / backup Supabase).
// O app continua usando estado local; este schema prepara as tabelas no PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id              String  @id
  instrument      String
  instrumentLabel String
  stage           Int
  monthlyPrice    Decimal @db.Decimal(12, 2)
}

model Teacher {
  id              String   @id
  nome            String
  dataNascimento  String
  naturalidade    String
  filiacao        String
  rg              String
  cpf             String
  endereco        String
  contatos        String
  email           String
  celular         String
  login           String
  senha           String
  instrumentSlugs String[]
  schedule        Json
}

model Student {
  id                      String  @id
  codigo                  String
  nome                    String
  dataNascimento          String
  rg                      String
  cpf                     String
  filiacao                String
  endereco                String
  telefone                String
  email                   String
  login                   String
  senha                   String
  responsavel             Json?
  enrollment              Json?
  status                  String
  dataCancelamento        String?
  observacoesCancelamento String?
}

model Mensalidade {
  id              String   @id
  studentId       String
  studentNome     String
  courseId        String
  courseLabel     String
  parcelNumber    Int
  referenceMonth  String
  dueDate         String
  baseAmount      Decimal  @db.Decimal(12, 2)
  discountPercent Int
  liquidAmount    Decimal  @db.Decimal(12, 2)
  generatedAt     String
  waivesLateFees  Boolean
  paidAt          String?
  status          String
}

model LessonLog {
  id         String  @id
  teacherId  String
  studentId  String
  lessonDate String
  slotKey    String
  present    Boolean
  content    String
  updatedAt  String
}

model ReplacementClass {
  id          String   @id
  studentId   String
  studentNome String
  teacherId   String
  teacherNome String
  date        String
  startTime   String
  duration    Int
  status      String
  content     String
  present     Boolean?
}

model SchoolSettings {
  id                  String @id @default("default")
  observacoesInternas String @default("")
}

/** Secretaria (admin) — login no app usa VITE_ADMIN_*; aqui guardamos hash para auditoria/API futura. */
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}
