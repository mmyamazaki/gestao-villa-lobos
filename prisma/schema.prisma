// Schema PostgreSQL (Supabase). Cursos, professores e alunos são persistidos via API + Prisma.
// Parcelas, logs e reposições permanecem no armazenamento local do navegador até migração futura.

generator client {
  provider = "prisma-client-js"
}

// DATABASE_URL: no Supabase use "Connection pooling" (porta 6543) em produção para evitar "too many connections".
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id              String  @id
  instrument      String
  instrumentLabel String
  /** Nível ou ano (texto livre), ex.: "Pré", "4º/5º ano". */
  levelLabel      String
  monthlyPrice    Decimal @db.Decimal(12, 2)
}

model Teacher {
  id              String   @id
  nome            String
  dataNascimento  String
  naturalidade    String
  filiacao        String
  rg              String
  cpf             String
  endereco        String
  contatos        String
  email           String
  celular         String
  login           String
  senha           String
  instrumentSlugs String[]
  schedule        Json
}

model Student {
  id                      String  @id
  codigo                  String
  nome                    String
  dataNascimento          String
  rg                      String
  cpf                     String
  filiacao                String
  endereco                String
  telefone                String
  email                   String
  login                   String
  senha                   String
  responsavel             Json?
  enrollment              Json?
  status                  String
  dataCancelamento        String?
  observacoesCancelamento String?
}

model Mensalidade {
  id              String   @id
  studentId       String
  studentNome     String
  courseId        String
  courseLabel     String
  parcelNumber    Int
  referenceMonth  String
  dueDate         String
  baseAmount      Decimal  @db.Decimal(12, 2)
  discountPercent Int
  liquidAmount    Decimal  @db.Decimal(12, 2)
  generatedAt     String
  waivesLateFees  Boolean
  paidAt          String?
  status          String
}

model LessonLog {
  id         String  @id
  teacherId  String
  studentId  String
  lessonDate String
  slotKey    String
  present    Boolean
  content    String
  updatedAt  String
}

model ReplacementClass {
  id          String   @id
  studentId   String
  studentNome String
  teacherId   String
  teacherNome String
  date        String
  startTime   String
  duration    Int
  status      String
  content     String
  present     Boolean?
}

model SchoolSettings {
  id                  String @id @default("default")
  observacoesInternas String @default("")
}

/**
 * Administradores da secretaria.
 * Senha: apenas hash bcrypt na coluna password_hash (nunca texto puro).
 */
model Admin {
  /** DEFAULT no PostgreSQL para inserts sem id (PostgREST). O app também envia crypto.randomUUID() no formulário. */
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  /** DEFAULT now() no PostgreSQL — necessário para inserts via PostgREST sem enviar timestamps. */
  createdAt    DateTime @default(dbgenerated("now()")) @map("created_at")
  /** DEFAULT now() no INSERT; trigger `admins_touch_updated_at` mantém em UPDATEs (ver prisma/sql/). */
  updatedAt    DateTime @default(dbgenerated("now()")) @updatedAt @map("updated_at")

  @@map("admins")
}
