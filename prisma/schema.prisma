// Schema PostgreSQL (Supabase). Cursos, professores e alunos são persistidos via API + Prisma.
// Parcelas: persistidas na tabela Mensalidade (API PUT ao salvar matrícula e ao registrar pagamento).
// Registos de aula (LessonLog): sincronizados via API PUT/GET /api/lesson-logs (+ Supabase opcional).
// Reposições (ReplacementClass): sincronizadas via API /api/replacement-classes (+ Supabase opcional).
// SchoolSettings: GET/PUT /api/school/settings.

generator client {
  provider = "prisma-client-js"
}

// DATABASE_URL: server/prisma.ts ajusta Supabase pooler (6543→5432 sessão) ou :6543 com pgbouncer.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id              String  @id
  instrument      String
  instrumentLabel String
  /** Nível ou ano (texto livre), ex.: "Pré", "4º/5º ano". */
  levelLabel      String
  monthlyPrice    Decimal @db.Decimal(12, 2)
}

model Teacher {
  id              String   @id
  nome            String
  dataNascimento  String
  naturalidade    String
  filiacao        String
  rg              String
  cpf             String
  endereco        String
  contatos        String
  email           String
  celular         String
  login           String
  senha           String
  instrumentSlugs String[]
  schedule        Json
}

model Student {
  id                      String  @id
  codigo                  String
  nome                    String
  dataNascimento          String
  rg                      String
  cpf                     String
  filiacao                String
  endereco                String
  telefone                String
  email                   String
  login                   String
  senha                   String
  responsavel             Json?
  enrollment              Json?
  status                  String
  dataCancelamento        String?
  observacoesCancelamento String?
}

model Mensalidade {
  id              String   @id
  studentId       String
  studentNome     String
  courseId        String
  courseLabel     String
  parcelNumber    Int
  referenceMonth  String
  dueDate         String
  baseAmount      Decimal  @db.Decimal(12, 2)
  discountPercent Int
  liquidAmount    Decimal  @db.Decimal(12, 2)
  generatedAt     String
  waivesLateFees  Boolean
  paidAt          String?
  status          String
  /** Multa (R$) efetiva no pagamento; nulo em parcelas antigas / não quitadas. */
  manualFine      Decimal? @db.Decimal(12, 2) @map("manual_fine")
  /** Juros (R$) efetivos no pagamento. */
  manualInterest  Decimal? @db.Decimal(12, 2) @map("manual_interest")
  /** Obrigatório quando multa/juros diferem do cálculo automático. */
  adjustmentNotes String?  @map("adjustment_notes") @db.Text
}

model LessonLog {
  id         String  @id
  teacherId  String
  studentId  String
  lessonDate String
  slotKey    String
  present    Boolean
  content    String
  updatedAt  String
}

model ReplacementClass {
  id          String   @id
  studentId   String
  /** Coluna no Postgres/Supabase: `studentName` */
  studentNome String   @map("studentName")
  teacherId   String
  /** Coluna no Postgres/Supabase: `teacherName` */
  teacherNome String   @map("teacherName")
  date        String
  startTime   String
  duration    Int      @map("duration")
  status      String
  content     String
  present     Boolean?
  /** ISO 8601 — resolução de conflitos ao sincronizar entre dispositivos */
  updatedAt   String   @default("") @map("updatedAt")
}

/** Observações internas da secretaria — GET/PUT `/api/school/settings` (sincroniza entre dispositivos). */
model SchoolSettings {
  id                  String @id @default("default")
  observacoesInternas String @default("")
}

/**
 * Administradores da secretaria.
 * Senha: apenas hash bcrypt na coluna password_hash (nunca texto puro).
 */
model Admin {
  /** DEFAULT no PostgreSQL para inserts sem id (PostgREST). O app também envia crypto.randomUUID() no formulário. */
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  /** DEFAULT now() no PostgreSQL — necessário para inserts via PostgREST sem enviar timestamps. */
  createdAt    DateTime @default(dbgenerated("now()")) @map("created_at")
  /** DEFAULT now() no INSERT; trigger `admins_touch_updated_at` mantém em UPDATEs (ver prisma/sql/). */
  updatedAt    DateTime @default(dbgenerated("now()")) @updatedAt @map("updated_at")

  @@map("admins")
}
