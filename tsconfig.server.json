{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist-server",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["server/**/*.ts", "src/domain/types.ts"]
}
